{
  "name": "poison-well-records",
  "private": true,
  "version": "1.0.0",
  "description": "Poison Well Records storefront with Netlify checkout functions",
  "scripts": {
    "check:js": "node --check site.js && node --check netlify/functions/_stripe-products.js && node --check netlify/functions/create-checkout-session.js",
    "dev": "http-server -p 3000",
    "stripe:test:preflight": "node scripts/stripe-test.js",
    "stripe:test:session": "node scripts/stripe-test.js --create-session"
  },
  "dependencies": {
    "stripe": "^20.4.1"
  }
}
